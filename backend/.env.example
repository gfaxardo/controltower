# Base de datos (producción: 168.119.226.236)
DB_HOST=168.119.226.236
DB_PORT=5432
DB_NAME=yego_integral
DB_USER=yego_user
DB_PASSWORD=

# Backend: en producción detrás de nginx debe escuchar solo en localhost
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# CORS: orígenes del front (añade tu IP/dominio si falta)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://162.55.214.109,https://162.55.214.109,http://5.161.86.63,https://5.161.86.63

# Login: destino real hacia api-int (solo el backend; el navegador usa /api/auth/login en el mismo host)
# INTEGRAL_AUTH_LOGIN_URL=https://api-int.yego.pro/api/auth/login

# ── Omniview REAL: refresh + watchdog (producción: activar refresh o watchdog según necesidad) ──
# OMNIVIEW_REAL_REFRESH_ENABLED=true
# OMNIVIEW_REAL_REFRESH_INTERVAL_MINUTES=30
# OMNIVIEW_REAL_REFRESH_MIN_INTERVAL_MINUTES=15
# OMNIVIEW_REAL_WATCHDOG_ENABLED=true
# OMNIVIEW_REAL_WATCHDOG_INTERVAL_MINUTES=15
# OMNIVIEW_UPSTREAM_MODE=table
# OMNIVIEW_UPSTREAM_TRIPS_TABLE=public.trips_2026
# OMNIVIEW_UPSTREAM_DATE_COLUMN=fecha_inicio_viaje
# OMNIVIEW_UPSTREAM_RECENT_DAYS=7
# REAL_FRESHNESS_ALERT_WEBHOOK=

# ── Projection Integrity Engine (Omniview derivación mensual → semanal/diario) ──
# PROJECTION_SMOOTHING_ALPHA_WEEK=0.7
# PROJECTION_SMOOTHING_ALPHA_DAY=0.7
# PROJECTION_CONSERVATION_TOLERANCE_PCT=0.1
