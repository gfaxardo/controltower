# Opcional. Si no existe .env, en producción se usa /api (mismo origen con nginx).
# Solo crea .env si quieres otra URL, ej. directo al backend: VITE_API_URL=http://162.55.214.109:8000
# VITE_API_URL=

# Login: siempre /api/auth/login (mismo origen). No pongas URL absoluta a api-int aquí (CORS en el navegador).
# Login obligatorio por defecto. Sin credenciales en local: VITE_AUTH_REQUIRED=false
# VITE_AUTH_REQUIRED=false

# Control Tower: si true, muestra todos los tabs (Plan Válido, Expansión, etc.) en la barra principal.
# Si false (por defecto), solo se muestran "Real LOB" y "Legacy"; el resto está dentro de Legacy.
VITE_CT_LEGACY_ENABLED=false

# Omniview Matrix: si true, no ejecuta al abrir la vista las consultas pesadas a la API/BD
# (matriz mensual/semanal/diaria, Data Trust, freshness operativo, cobertura) hasta pulsar «Cargar datos».
# Útil para depurar sin saturar PostgreSQL. En desarrollo suele activarse vía .env.development.
# VITE_OMNIVIEW_MATRIX_MANUAL_LOAD=false
